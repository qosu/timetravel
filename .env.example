# ═══════════════════════════════════════════════════════════════
# TimeTravel — API Key Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
#
# Format: comma-separated keys per provider.
#   GROQ_KEYS=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   OPENROUTER_KEYS=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxx
#   CEREBRAS_KEYS=csk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ═══════════════════════════════════════════════════════════════

# Groq (required for: secondary_feedback, safe_modification demos)
GROQ_KEYS=

# OpenRouter (required for: demo_alignment, value_reflection)
OPENROUTER_KEYS=

# Mistral
MISTRAL_KEYS=

# Cohere
COHERE_KEYS=

# SambaNova
SAMBANOVA_KEYS=

# Cloudflare Workers AI
CLOUDFLARE_TOKENS=
CLOUDFLARE_ACCOUNTS=

# Cerebras
CEREBRAS_KEYS=
